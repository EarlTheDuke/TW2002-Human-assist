# TW2K-AI environment variables
#
# Copy this file to `.env` (ignored by git) or export these in your shell.
# Only the provider you intend to use needs to be set.

# ---------- xAI (Grok) ----------
# Default recommended provider.
XAI_API_KEY=xai-your-key-here
TW2K_XAI_MODEL=grok-4-1-fast-reasoning

# ---------- OpenAI ----------
# OPENAI_API_KEY=sk-your-key-here
# TW2K_OPENAI_MODEL=gpt-4o-mini

# ---------- Anthropic ----------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# TW2K_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929   # or claude-sonnet-4-6-... when available

# ---------- Custom / OpenAI-compatible endpoint ----------
# TW2K_CUSTOM_BASE_URL=https://your-endpoint/v1
# TW2K_CUSTOM_API_KEY=your-key-here
# TW2K_CUSTOM_MODEL=qwen3.5:122b

# ---------- Cursor Agent CLI (Composer, etc.) ----------
# Requires the `agent` binary from https://cursor.com/install
#   PowerShell: irm 'https://cursor.com/install?win32=true' | iex
# Then: agent login   OR set:
# CURSOR_API_KEY=your-cursor-api-key
#
# TW2K_CURSOR_MODEL=composer-2-fast
# TW2K_CURSOR_CLI=     # optional full path if `agent` is not on PATH
# TW2K_CURSOR_WORKSPACE=   # optional repo root (defaults to process cwd)
# TW2K_CURSOR_THINK_CAP_S=180   # optional per-turn timeout override
# TW2K_CURSOR_CMDLINE_BUDGET=30000   # if system+obs exceeds this, minimal prompt is used (Windows limit)

# ---------- Provider selection (optional) ----------
# Forces a provider instead of auto-detecting from the keys above.
# Values: auto | xai | openai | anthropic | custom
# TW2K_PROVIDER=xai

# ---------- Encoding (Windows-only; avoids UnicodeEncodeError on console I/O) ----------
# PYTHONIOENCODING=utf-8
# PYTHONUTF8=1
